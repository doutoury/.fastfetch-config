    //   "left": 0,
    //   "right": 2
    // }
  },
  "display": {
    "separator": " : ",
    "color": "38;2;255;136;0"
  },
  "modules": [
    "title",
    "separator",
    "os",
    "kernel",
    "de",
    "wm",
    "wmtheme",
    "host",
    "shell",
    "terminal",
    "terminalfont",
    "packages",
    "theme",
    "locale",
    "separator",
    // "icons",
    // "font",
    // "cursor",
    "display",
    "cpu",
    "gpu",
    "memory",
    "swap",
