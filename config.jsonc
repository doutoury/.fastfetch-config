{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    // image location
    "source": "~/fastfetch/my_ascii.txt",
    "type": "auto", 
    // fastfetch color representation: "38;2;r;g;b" (r, g, b bit)
    "color": {"1": "38;2;255;136;0", 
              "2": "38;2;255;136;0", 
              "3": "38;2;255;136;0", },
